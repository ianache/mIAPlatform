# Database
POSTGRES_USER=miaplatform
POSTGRES_PASSWORD=changeme
POSTGRES_DB=miaplatform
MONGO_USER=miaplatform
MONGO_PASSWORD=changeme
NEO4J_PASSWORD=changeme

# Vault
VAULT_URL=http://localhost:8200
VAULT_TOKEN=changeme

# Keycloak (public client — Authorization Code Flow + PKCE, no client secret needed)
# Production QA host — realm 'Apps', client 'miaplatform' must have Standard Flow enabled
# and redirect URI http://localhost:5173/ registered.
KEYCLOAK_URL=https://oauth2.qa.comsatel.com.pe
KEYCLOAK_REALM=Apps
KEYCLOAK_CLIENT_ID=miaplatform
KEYCLOAK_ADMIN=admin
KEYCLOAK_PASSWORD=changeme

# LLM Providers (to be configured per tenant)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# App
NODE_ENV=development
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Frontend (Vite) — copy these to src/frontend/.env or set in your shell
VITE_KEYCLOAK_URL=https://oauth2.qa.comsatel.com.pe
VITE_KEYCLOAK_REALM=Apps
VITE_KEYCLOAK_CLIENT_ID=miaplatform

GITLAB_TOKEN=